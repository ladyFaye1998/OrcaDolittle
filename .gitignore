# --- Embeddings: keep only labeled artifacts in repo ---
# `*_full_embeddings.npz` is a strict subset of `*_full_labeled.npz`
# (same embeddings + metadata, no labels array) — derivable, do not commit.
data/embeddings/*_full_embeddings.npz
# Call-type encode artifact: large and reproducible from notebooks/calltype_encode_colab.ipynb;
# the committed result is reports/calltype_model_full_summary.json + figures/calltype_model_full.png.
data/embeddings/*_calltype_embeddings.npz
data/embeddings/audio_cache/
data/dclde/audio_cache/

# Playback head (H6): public FEROP catalogue audio + AVES2 encode cache are
# reproducible from scripts/build_playback_manifest.py + run_playback_response.py.
# The manifest and per-trial table (data/join_tables/) ARE committed.
data/playback/ferop_catalogue/
data/playback/*.npz

